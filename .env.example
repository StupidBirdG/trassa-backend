# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trassa_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT — любая длинная случайная строка (генерируй: openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# SMSC.kz (регистрация на smsc.kz)
SMSC_LOGIN=your_smsc_login
SMSC_PASSWORD=your_smsc_password
SMSC_SENDER=TRASSA       # имя отправителя — нужно согласовать с SMSC

# Сервер
PORT=3001
NODE_ENV=development
