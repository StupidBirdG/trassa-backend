# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trassa_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT — любая длинная случайная строка (генерируй: openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# Vonage (бывший Nexmo) — международный SMS-провайдер (dashboard.nexmo.com)
# Заменил SMSC.kz — используется как fallback, когда у номера нет привязанного Telegram-бота
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_FROM=Trassa      # имя/номер отправителя — для некоторых стран (в т.ч. может требоваться для KZ) нужен реальный номер вместо буквенного имени, уточнить в личном кабинете Vonage

# Сервер
PORT=3001
NODE_ENV=development
