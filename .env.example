# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trassa_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT — любая длинная случайная строка (генерируй: openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# Infobip — международный SMS-провайдер (portal.infobip.com)
# Заменил Vonage 2026-07-08 (Vonage принимал и списывал за SMS, но не доставлял в KZ).
# Используется как fallback, когда у номера нет привязанного Telegram-бота.
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://xxxxxxx.api.infobip.com   # индивидуальный для аккаунта, см. личный кабинет
INFOBIP_FROM=                                       # необязательно — оставь пустым для дефолтного маршрута

# Сервер
PORT=3001
NODE_ENV=development
