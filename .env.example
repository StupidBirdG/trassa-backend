# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trassa_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT — любая длинная случайная строка (генерируй: openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# Infobip — международный SMS-провайдер (portal.infobip.com)
# Заменил Vonage 2026-07-08 (Vonage принимал и списывал за SMS, но не доставлял в KZ).
# Используется как fallback, когда у номера нет привязанного Telegram-бота.
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://xxxxxxx.api.infobip.com   # индивидуальный для аккаунта, см. личный кабинет
INFOBIP_FROM=                                       # необязательно — оставь пустым для дефолтного маршрута

# WhatsApp через тот же Infobip-аккаунт (используется как fallback между Telegram и SMS).
# Требует одобренный Meta номер-отправитель (Channels & Numbers → WhatsApp в портале Infobip).
INFOBIP_WHATSAPP_FROM=                              # номер без +, например 447860089847

# PayBox.money — платёжный агрегатор для оплаты подписки (карты + Kaspi QR/Kaspi Pay).
# Личный кабинет мерчанта: https://paybox.money. Без этих переменных оплата картой/Kaspi
# просто недоступна (503 payments_not_configured), остальной сервер работает нормально.
PAYBOX_MERCHANT_ID=your_paybox_merchant_id
PAYBOX_SECRET_KEY=your_paybox_secret_key

# Ручной перевод на Kaspi Gold — временное решение, пока у владельца нет ИП/самозанятости
# (нужно для KYC у любого реального агрегатора). Оплата подтверждается вручную в
# админ-панели после того, как деньги реально пришли на этот номер.
KASPI_PHONE=+7XXXXXXXXXX
KASPI_RECIPIENT_NAME=Имя Фамилия

# Мониторинг/алерты (2026-07-09): падение процесса/БД, необработанная 500-ка, новая
# жалоба, новый Kaspi-платёж на подтверждение — всё шлётся владельцу в личку боту
# TRASSA. Получить свой chat_id: напиши боту /start один раз, дальше см. README/чат.
# Без этой переменной алерты просто no-op, остальной сервер работает нормально.
ADMIN_TELEGRAM_CHAT_ID=your_telegram_chat_id

# Web Push (2026-07-10) — уведомление перевозчиков о новом грузе без Telegram, через
# уже готовую PWA. Ключи одноразово генерируются: `npx web-push generate-vapid-keys`
# (или node -e "console.log(require('web-push').generateVAPIDKeys())"). Без этих
# переменных пуш просто no-op (503 на /api/push/vapid-public-key), остальной сервер работает.
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Сервер
PORT=3001
NODE_ENV=development
